{
  "name": "todohub-typescript-action",
  "description": "Github action that collects TODOs in code and sorts them into issues",
  "version": "0.0.1",
  "author": "nigeisel",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/todos-in/todohub",
  "keywords": [
    "github",
    "actions",
    "node",
    "todos",
    "issues"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": "24.13.0"
  },
  "scripts": {
    "lint": "npx eslint .",
    "lint-fix": "npx eslint --fix .",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test-coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "coverage-badge": "make-coverage-badge --output-path ./badges/coverage.svg",
    "bundle": "ncc build src/index.ts --license licenses.txt",
    "bundle-debug": "tsc -p tsconfig.json",
    "release": "npm ci && npm run lint && npm run test-coverage && npm run bundle && npm run coverage-badge"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-paginate-rest": "^14.0.0",
    "@octokit/plugin-rest-endpoint-methods": "^17.0.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks-types": "^7.5.0",
    "brandi": "^5.1.0",
    "ignore": "^7.0.5",
    "tar-stream": "^3.1.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^1.7.2",
    "@types/jest": "^29.5.12",
    "@types/node": "24.12.2",
    "@types/tar-stream": "^3.1.4",
    "@typescript-eslint/eslint-plugin": "7.7.0",
    "@typescript-eslint/parser": "7.7.0",
    "@vercel/ncc": "0.38.4",
    "eslint": "^8.57.0",
    "eslint-plugin-jest": "^28.2.0",
    "eslint-plugin-jsonc": "^2.15.1",
    "eslint-plugin-todohub": "0.2.5",
    "jest": "^30.3.0",
    "make-coverage-badge": "^1.2.0",
    "tar": "^7.5.13",
    "ts-jest": "^29.4.9",
    "typescript": "5.4.5"
  }
}
